{
  "name": "timesheet-app",
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node server/index.js\" \"vite\" \"vite --config vite.admin.config.js\"",
    "dev:app": "vite",
    "dev:admin": "vite --config vite.admin.config.js",
    "build": "vite build && vite build --config vite.admin.config.js",
    "build:admin": "vite build --config vite.admin.config.js",
    "start": "node server/index.js",
    "seed": "node server/db/seed.js",
    "migrate:timesheet-clientid": "node scripts/backfill-timesheet-clientId.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@aws-sdk/client-s3": "^3.988.0",
    "@fluentui/react-components": "^9.54.0",
    "@fluentui/react-datepicker-compat": "^0.4.0",
    "@fluentui/react-icons": "^2.0.245",
    "@uiw/react-md-editor": "^4.0.11",
    "archiver": "^7.0.1",
    "dotenv": "^17.2.4",
    "express": "^4.21.0",
    "multer": "^2.0.2",
    "nedb-promises": "^6.2.3",
    "node-cron": "^4.2.1",
    "node-ical": "^0.25.6",
    "odata-filter-to-ast": "^4.0.0",
    "pdf-lib": "^1.17.1",
    "pdfmake": "^0.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "sharp": "^0.34.5",
    "tar": "^7.5.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.0",
    "vite": "^5.4.0"
  }
}
